generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BudgetProfile {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userId            String?
  monthlyIncome     Float
  recurringIncome   Float
  savingsGoal       Float
  fixedExpenses     Float
  variableExpenses  Float
  debtRepayments    Float

  user              User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  chartConfigs      ChartConfig[]
  categoryLimits    CategoryLimit[]
  recurringRules    RecurringTransaction[]
  monthlySnapshots  MonthlySnapshot[]

  @@index([userId, createdAt])
}

model Transaction {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())

  budgetProfileId String
  date            DateTime
  amount          Float
  type            String
  category        String
  note            String?

  budgetProfile   BudgetProfile @relation(fields: [budgetProfileId], references: [id], onDelete: Cascade)

  @@index([budgetProfileId, date(sort: Desc), createdAt(sort: Desc)])
  @@index([budgetProfileId, type, category])
}

model ChartConfig {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budgetProfileId String
  chartKey        String
  title           String
  configJson      String

  budgetProfile   BudgetProfile @relation(fields: [budgetProfileId], references: [id], onDelete: Cascade)

  @@index([budgetProfileId, createdAt])
}

model CategoryLimit {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budgetProfileId String
  category        String
  monthlyLimit    Float

  budgetProfile   BudgetProfile @relation(fields: [budgetProfileId], references: [id], onDelete: Cascade)

  @@unique([budgetProfileId, category])
  @@index([budgetProfileId, category])
}

model RecurringTransaction {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  budgetProfileId String
  name            String
  amount          Float
  type            String
  category        String
  note            String?
  cadence         String
  dayOfMonth      Int?
  weekday         Int?
  nextRunDate     DateTime
  isActive        Boolean  @default(true)
  lastAppliedAt   DateTime?

  budgetProfile   BudgetProfile @relation(fields: [budgetProfileId], references: [id], onDelete: Cascade)

  @@index([budgetProfileId, nextRunDate])
  @@index([budgetProfileId, isActive, nextRunDate])
}

model MonthlySnapshot {
  id                    String   @id @default(cuid())
  createdAt             DateTime @default(now())

  budgetProfileId       String
  monthKey              String
  totalIncome           Float
  totalExpenses         Float
  remainingThisMonth    Float
  projectedEndOfMonth   Float
  safeToSpendToday      Float
  budgetUsedPercentage  Float
  savingsGap            Float

  budgetProfile         BudgetProfile @relation(fields: [budgetProfileId], references: [id], onDelete: Cascade)

  @@unique([budgetProfileId, monthKey])
  @@index([budgetProfileId, monthKey])
}

model User {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  email           String   @unique
  passwordHash    String
  displayName     String?

  sessions        Session[]
  budgetProfiles  BudgetProfile[]
}

model Session {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  expiresAt       DateTime
  tokenHash       String   @unique

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
